# ============================================================
# PeoplePulse AI — .gitignore
# ============================================================

# Environment & secrets
.env
*.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Streamlit
.streamlit/secrets.toml

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ML model artifacts (large binaries — track via DVC/LFS if needed)
ml_models/artifacts/*.pkl
ml_models/artifacts/*.joblib
ml_models/artifacts/*.json
!ml_models/artifacts/.gitkeep

# Data (uncomment if dataset shouldn't be committed — included by default for portfolio reproducibility)
# data/*.csv

# Power BI
*.pbix.bak
~$*.pbix

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Docker
*.pid
